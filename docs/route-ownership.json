{
  "schemaVersion": 1,
  "description": "Single source of truth for route and product responsibility ownership during Node runtime removal.",
  "publicHttpSource": "docs/openapi.json",
  "runtimeRegistries": {
    "node": {
      "source": "src/server.js",
      "extractor": "node-url-pathname-method"
    },
    "rust": {
      "source": "apps/windows/src",
      "extractor": "rust-literal-route-tuples"
    }
  },
  "publicRouteFamilies": [
    { "id": "discovery", "owner": "node", "status": "node-owned", "prefixes": ["/api/tool-registry", "/api/command-registry"] },
    { "id": "openapi", "owner": "rust", "status": "default-on", "prefixes": ["/api/openapi.json"] },
    { "id": "provider-registry", "owner": "rust", "status": "default-on", "prefixes": ["/api/provider-registry"] },
    { "id": "status", "owner": "rust", "status": "default-on", "prefixes": ["/api/status"] },
    { "id": "doctor", "owner": "rust", "status": "default-on", "prefixes": ["/api/doctor"] },
    { "id": "agent-reach", "owner": "node", "status": "node-owned", "prefixes": ["/api/agent-reach"] },
    { "id": "doubao", "owner": "node", "status": "node-owned", "prefixes": ["/api/doubao"] },
    { "id": "mcp", "owner": "node", "status": "node-owned", "prefixes": ["/api/mcp"] },
    { "id": "histories", "owner": "rust", "status": "default-on", "prefixes": ["/api/histories"] },
    { "id": "search", "owner": "rust", "status": "default-on", "prefixes": ["/api/search"] },
    { "id": "tasks", "owner": "rust", "status": "default-on", "prefixes": ["/api/tasks", "/api/task-scheduler", "/api/context-budget", "/api/compact"] },
    { "id": "workspaces", "owner": "rust", "status": "default-on", "prefixes": ["/api/workspaces"] },
    { "id": "tool-runs", "owner": "rust", "status": "phase-2-persisted", "prefixes": ["/api/tool-runs"] },
    { "id": "tool-events", "owner": "rust", "status": "default-on", "prefixes": ["/api/tool-events"] },
    { "id": "approvals", "owner": "rust", "status": "phase-2-persisted", "prefixes": ["/api/approvals"] },
    { "id": "devices", "owner": "rust", "status": "default-on", "prefixes": ["/api/devices"] },
    { "id": "pairing", "owner": "rust", "status": "default-on", "prefixes": ["/api/login", "/api/pairing-sessions"] },
    { "id": "events", "owner": "rust", "status": "default-on", "prefixes": ["/api/events"] },
    { "id": "live-calls", "owner": "node", "status": "node-owned", "prefixes": ["/api/live-calls"] },
    { "id": "settings", "owner": "rust", "status": "default-on", "prefixes": ["/api/settings"] },
    { "id": "thread-state", "owner": "rust", "status": "default-on", "prefixes": ["/api/thread-state"] },
    { "id": "reviews", "owner": "node", "status": "node-owned", "prefixes": ["/api/reviews"] },
    { "id": "audit", "owner": "rust", "status": "default-on", "prefixes": ["/api/audit-log"] },
    { "id": "desktop-remote", "owner": "rust", "status": "default-on", "routes": ["GET /api/desktop-remote/observations"] },
    { "id": "desktop-remote-control", "owner": "node", "status": "node-owned", "routes": ["GET /api/desktop-remote/status", "GET /api/desktop-remote/events", "POST /api/desktop-remote/messages", "POST /api/desktop-remote/retry", "POST /api/desktop-remote/clear", "POST /api/desktop-remote/focus"] },
    { "id": "terminal-sessions", "owner": "rust", "status": "default-on", "prefixes": ["/api/terminal-sessions"] },
    { "id": "artifacts", "owner": "rust", "status": "default-on", "prefixes": ["/api/artifacts"] },
    { "id": "browser-sessions", "owner": "node", "status": "node-owned", "prefixes": ["/api/browser-sessions", "/api/browser"] },
    { "id": "capabilities", "owner": "node", "status": "node-owned", "prefixes": ["/api/capabilities"] },
    { "id": "automations", "owner": "node", "status": "node-owned", "prefixes": ["/api/automations"] },
    { "id": "subagents", "owner": "node", "status": "node-owned", "prefixes": ["/api/subagents"] },
    { "id": "cloudflare", "owner": "node", "status": "node-owned", "prefixes": ["/api/cloudflare"] },
    { "id": "push", "owner": "node", "status": "node-owned", "prefixes": ["/api/push"] },
    { "id": "attachments", "owner": "rust", "status": "default-on", "prefixes": ["/api/attachments"] },
    { "id": "files", "owner": "rust", "status": "default-on", "prefixes": ["/api/files"] },
    { "id": "codex-desktop", "owner": "node", "status": "node-owned", "prefixes": ["/api/codex-desktop", "/api/codex-app-server"] }
  ],
  "internalRouteFamilies": [],
  "responsibilities": [
    { "id": "workspace-command-execution", "owner": "rust", "status": "phase-2-persisted" },
    { "id": "approval-continuation", "owner": "rust", "status": "phase-2-persisted" },
    { "id": "task-history-terminal-runtime", "owner": "rust", "status": "default-on" },
    { "id": "provider-registry-runtime", "owner": "rust", "status": "default-on" },
    { "id": "live-call-asr-audio-runtime", "owner": "node", "status": "node-owned" },
    { "id": "search-index-runtime", "owner": "node", "status": "node-owned" },
    { "id": "browser-session-runtime", "owner": "node", "status": "node-owned" },
    { "id": "artifact-storage-runtime", "owner": "rust", "status": "required-for-rust-only" },
    { "id": "automation-scheduler-runtime", "owner": "node", "status": "node-owned" },
    { "id": "push-notification-runtime", "owner": "node", "status": "node-owned" },
    { "id": "desktop-observation-runtime", "owner": "rust", "status": "default-on" },
    { "id": "desktop-remote-control-runtime", "owner": "node", "status": "node-owned" },
    { "id": "static-asset-serving", "owner": "rust", "status": "required-for-rust-only" }
  ],
  "rustOnlyAcceptance": {
    "requiredFamilies": [
      "discovery",
      "openapi",
      "provider-registry",
      "status",
      "doctor",
      "agent-reach",
      "doubao",
      "mcp",
      "histories",
      "search",
      "tasks",
      "workspaces",
      "tool-runs",
      "tool-events",
      "approvals",
      "devices",
      "pairing",
      "events",
      "live-calls",
      "settings",
      "thread-state",
      "reviews",
      "audit",
      "desktop-remote",
      "desktop-remote-control",
      "terminal-sessions",
      "artifacts",
      "browser-sessions",
      "capabilities",
      "automations",
      "subagents",
      "cloudflare",
      "push",
      "attachments",
      "files",
      "codex-desktop"
    ],
    "requiredTransports": ["http", "sse", "websocket"],
    "packageSmoke": "tools/rust-only-package-smoke.mjs",
    "forbiddenPackageEntries": ["runtime/node.exe", "src/", "node_modules/", "package.json"],
    "forbiddenProcessNames": ["node.exe"]
  }
}

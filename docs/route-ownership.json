{
  "schemaVersion": 1,
  "description": "Single source of truth for route and product responsibility ownership during Node runtime removal.",
  "publicHttpSource": "docs/openapi.json",
  "runtimeRegistries": {
    "node": {
      "source": "src/server.js",
      "extractor": "node-url-pathname-method"
    },
    "rust": {
      "source": "apps/windows/src",
      "extractor": "rust-literal-route-tuples"
    }
  },
  "publicRouteFamilies": [
    { "id": "discovery", "owner": "node", "status": "node-owned", "prefixes": ["/api/tool-registry", "/api/provider-registry", "/api/command-registry", "/api/openapi.json"] },
    { "id": "status", "owner": "rust", "status": "default-on", "prefixes": ["/api/status"] },
    { "id": "doctor", "owner": "rust", "status": "default-on", "prefixes": ["/api/doctor"] },
    { "id": "agent-reach", "owner": "node", "status": "node-owned", "prefixes": ["/api/agent-reach"] },
    { "id": "doubao", "owner": "node", "status": "node-owned", "prefixes": ["/api/doubao"] },
    { "id": "mcp", "owner": "node", "status": "node-owned", "prefixes": ["/api/mcp"] },
    { "id": "histories", "owner": "node", "status": "node-owned", "prefixes": ["/api/histories"] },
    { "id": "search", "owner": "node", "status": "node-owned", "prefixes": ["/api/search"] },
    { "id": "tasks", "owner": "node", "status": "node-owned", "prefixes": ["/api/tasks", "/api/task-scheduler", "/api/context-budget", "/api/compact"] },
    { "id": "workspaces", "owner": "mixed", "status": "in-progress", "prefixes": ["/api/workspaces"] },
    { "id": "tool-runs", "owner": "node", "status": "node-owned", "prefixes": ["/api/tool-runs"] },
    { "id": "tool-events", "owner": "mixed", "status": "in-progress", "prefixes": ["/api/tool-events"] },
    { "id": "approvals", "owner": "node", "status": "node-owned", "prefixes": ["/api/approvals"] },
    { "id": "devices", "owner": "rust", "status": "default-on", "prefixes": ["/api/devices"] },
    { "id": "pairing", "owner": "rust", "status": "default-on", "prefixes": ["/api/login", "/api/pairing-sessions"] },
    { "id": "events", "owner": "rust", "status": "default-on", "prefixes": ["/api/events"] },
    { "id": "live-calls", "owner": "node", "status": "node-owned", "prefixes": ["/api/live-calls"] },
    { "id": "settings", "owner": "mixed", "status": "in-progress", "prefixes": ["/api/settings"] },
    { "id": "thread-state", "owner": "node", "status": "node-owned", "prefixes": ["/api/thread-state"] },
    { "id": "reviews", "owner": "node", "status": "node-owned", "prefixes": ["/api/reviews"] },
    { "id": "audit", "owner": "rust", "status": "default-on", "prefixes": ["/api/audit-log"] },
    { "id": "desktop-remote", "owner": "node", "status": "node-owned", "prefixes": ["/api/desktop-remote"] },
    { "id": "terminal-sessions", "owner": "node", "status": "node-owned", "prefixes": ["/api/terminal-sessions"] },
    { "id": "artifacts", "owner": "node", "status": "node-owned", "prefixes": ["/api/artifacts"] },
    { "id": "browser-sessions", "owner": "node", "status": "node-owned", "prefixes": ["/api/browser-sessions", "/api/browser"] },
    { "id": "capabilities", "owner": "node", "status": "node-owned", "prefixes": ["/api/capabilities"] },
    { "id": "automations", "owner": "node", "status": "node-owned", "prefixes": ["/api/automations"] },
    { "id": "subagents", "owner": "node", "status": "node-owned", "prefixes": ["/api/subagents"] },
    { "id": "cloudflare", "owner": "node", "status": "node-owned", "prefixes": ["/api/cloudflare"] },
    { "id": "push", "owner": "node", "status": "node-owned", "prefixes": ["/api/push"] },
    { "id": "attachments", "owner": "node", "status": "node-owned", "prefixes": ["/api/attachments"] },
    { "id": "files", "owner": "node", "status": "node-owned", "prefixes": ["/api/files"] },
    { "id": "codex-desktop", "owner": "node", "status": "node-owned", "prefixes": ["/api/codex-desktop", "/api/codex-app-server"] }
  ],
  "internalRouteFamilies": [
    { "id": "internal-status-snapshot", "owner": "node", "status": "hybrid-required", "routes": ["GET /internal/status-snapshot"] },
    { "id": "internal-doctor-report", "owner": "node", "status": "hybrid-required", "routes": ["GET /internal/doctor-report"] },
    { "id": "internal-public-settings", "owner": "node", "status": "hybrid-required", "routes": ["GET /internal/public-settings"] },
    { "id": "internal-reload-settings", "owner": "node", "status": "hybrid-required", "routes": ["POST /internal/reload-settings"] }
  ],
  "responsibilities": [
    { "id": "workspace-command-execution", "owner": "node", "status": "node-owned" },
    { "id": "approval-continuation", "owner": "node", "status": "node-owned" },
    { "id": "task-history-terminal-runtime", "owner": "node", "status": "node-owned" },
    { "id": "provider-registry-runtime", "owner": "node", "status": "node-owned" },
    { "id": "live-call-asr-audio-runtime", "owner": "node", "status": "node-owned" },
    { "id": "search-index-runtime", "owner": "node", "status": "node-owned" },
    { "id": "browser-session-runtime", "owner": "node", "status": "node-owned" },
    { "id": "artifact-storage-runtime", "owner": "node", "status": "node-owned" },
    { "id": "automation-scheduler-runtime", "owner": "node", "status": "node-owned" },
    { "id": "push-notification-runtime", "owner": "node", "status": "node-owned" },
    { "id": "desktop-remote-runtime", "owner": "node", "status": "node-owned" },
    { "id": "static-asset-serving", "owner": "rust", "status": "required-for-rust-only" }
  ],
  "rustOnlyAcceptance": {
    "requiredFamilies": [
      "discovery",
      "status",
      "doctor",
      "devices",
      "pairing",
      "events",
      "tool-events",
      "workspaces",
      "approvals",
      "tasks",
      "live-calls",
      "settings",
      "artifacts",
      "browser-sessions",
      "desktop-remote"
    ],
    "requiredTransports": ["http", "sse", "websocket"],
    "packageSmoke": "tools/rust-only-package-smoke.mjs",
    "forbiddenPackageEntries": ["runtime/node.exe", "src/", "node_modules/", "package.json"],
    "forbiddenProcessNames": ["node.exe"]
  }
}
